# App
APP_ENV=development
APP_PORT=8080
APP_NAME=wapgo-service
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database (DB_DRIVER: postgres | mysql)
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wapgo
DB_USER=wapgo
DB_PASSWORD=wapgo_secret
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFE=5m
DB_AUTO_MIGRATE=true
DB_SSL_MODE=disable      # use 'require' in production

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka (leave empty to report "not_configured" in /health)
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=wapgo-service-group

# RabbitMQ (leave empty to report "not_configured" in /health)
RABBITMQ_DSN=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=wapgo-exchange

# Logger
LOG_LEVEL=info
LOG_TO_FILE=false
LOG_FILE_PATH=logs/app.log

# External services
USER_SERVICE_URL=http://user-service:8080
ORDER_SERVICE_URL=http://order-service:8080

# ── Notification add-ons (opsional — biarkan kosong jika tidak dipakai) ──────

# SMTP (pkg/notification/email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587                  # 587=STARTTLS (recommended), 465=implicit TLS, 25=plain
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=smtp_password
SMTP_FROM=noreply@example.com
SMTP_TIMEOUT=10s

# Firebase FCM (pkg/notification/firebase)
# Cara dapat: Firebase Console → Project Settings → Service Accounts → Generate new private key
#
# Cara 1 — inline JSON (satu baris, \n di-escape):
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"my-app-12345","private_key_id":"abc123","private_key":"-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@my-app-12345.iam.gserviceaccount.com","token_uri":"https://oauth2.googleapis.com/token"}
#
# Cara 2 — dari file (direkomendasikan untuk lokal/CI):
# export FIREBASE_CREDENTIALS_JSON=$(cat path/to/serviceAccountKey.json)
#
# Cara 3 — Kubernetes Secret (production): isi via stringData di manifest Secret, bukan di sini
FIREBASE_CREDENTIALS_JSON=
