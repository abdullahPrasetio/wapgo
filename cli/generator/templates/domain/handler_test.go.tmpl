type mock[[.Pascal]]UC struct {
	item *entity.[[.Pascal]]
	list []*entity.[[.Pascal]]
	err  error
}

func (m *mock[[.Pascal]]UC) Get[[.Pascal]](_ context.Context, _ string) (*entity.[[.Pascal]], error) {
	return m.item, m.err
}
func (m *mock[[.Pascal]]UC) List[[.Pascal]]s(_ context.Context) ([]*entity.[[.Pascal]], error) {
	return m.list, m.err
}
func (m *mock[[.Pascal]]UC) Create[[.Pascal]](_ context.Context, _ *usecase.Create[[.Pascal]]Request) (*entity.[[.Pascal]], error) {
