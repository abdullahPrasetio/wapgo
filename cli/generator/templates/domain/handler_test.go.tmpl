// test[[.Pascal]]App wires the handler onto a minimal Fiber app.
func test[[.Pascal]]App(h *handler.[[.Pascal]]Handler) *fiber.App {
	app := fiber.New(fiber.Config{DisableStartupMessage: true})
	app.Get("/[[.Table]]/:id", h.Get[[.Pascal]])
	app.Get("/[[.Table]]", h.List[[.Pascal]]s)
	app.Post("/[[.Table]]", h.Create[[.Pascal]])
	app.Put("/[[.Table]]/:id", h.Update[[.Pascal]])
	app.Delete("/[[.Table]]/:id", h.Delete[[.Pascal]])
	return app
}

func fake[[.Pascal]]() *entity.[[.Pascal]] {
	return &entity.[[.Pascal]]{}
}

func [[.Camel]]JSONBody(t *testing.T, v interface{}) *bytes.Buffer {
	t.Helper()
	b, err := json.Marshal(v)
	require.NoError(t, err)
	return bytes.NewBuffer(b)
}

// ── Get[[.Pascal]] ──────────────────────────────────────────────────────────────

func TestGet[[.Pascal]]_200(t *testing.T) {
	h := handler.New[[.Pascal]]Handler(&mock[[.Pascal]]UC{item: fake[[.Pascal]]()}, validator.New())
	req := httptest.NewRequest("GET", "/[[.Table]]/some-id", nil)
	resp, err := test[[.Pascal]]App(h).Test(req)
	require.NoError(t, err)
	assert.Equal(t, 200, resp.StatusCode)
}

func TestGet[[.Pascal]]_NotFound(t *testing.T) {
	h := handler.New[[.Pascal]]Handler(&mock[[.Pascal]]UC{err: usecase.Err[[.Pascal]]NotFound}, validator.New())
	req := httptest.NewRequest("GET", "/[[.Table]]/some-id", nil)
	resp, _ := test[[.Pascal]]App(h).Test(req)
	assert.Equal(t, 404, resp.StatusCode)
}

func TestGet[[.Pascal]]_InvalidUUID(t *testing.T) {
	h := handler.New[[.Pascal]]Handler(&mock[[.Pascal]]UC{err: usecase.Err[[.Pascal]]InvalidUUID}, validator.New())
	req := httptest.NewRequest("GET", "/[[.Table]]/bad", nil)
	resp, _ := test[[.Pascal]]App(h).Test(req)
	assert.Equal(t, 400, resp.StatusCode)
}

func TestGet[[.Pascal]]_InternalError(t *testing.T) {
	h := handler.New[[.Pascal]]Handler(&mock[[.Pascal]]UC{err: errors.New("db down")}, validator.New())
	req := httptest.NewRequest("GET", "/[[.Table]]/some-id", nil)
	resp, _ := test[[.Pascal]]App(h).Test(req)
	assert.Equal(t, 500, resp.StatusCode)
}

