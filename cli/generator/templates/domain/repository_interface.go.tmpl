// [[.Pascal]]Repository defines persistence operations for the [[.Snake]] domain.
// Implementation lives in internal/repository/postgres/.
type [[.Pascal]]Repository interface {
	FindByID(ctx context.Context, id uuid.UUID) (*entity.[[.Pascal]], error)
	FindAll(ctx context.Context) ([]*entity.[[.Pascal]], error)
