func Test[[.Pascal]]UseCase_Get[[.Pascal]]_OK(t *testing.T) {
	repo := new(mock[[.Pascal]]Repository)
	uc := usecase.New[[.Pascal]]UseCase(repo)
	ctx := context.Background()

	id := uuid.New()
	want := &entity.[[.Pascal]]{ID: id}
	repo.On("FindByID", ctx, id).Return(want, nil)

