# App
APP_ENV=development
APP_PORT=8080
APP_NAME=[[.AppName]]
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database (DB_DRIVER: postgres | mysql)
DB_DRIVER=[[.DB]]
DB_HOST=localhost
DB_PORT=[[if eq .DB "mysql"]]3306[[else]]5432[[end]]
DB_NAME=[[.AppName]]
DB_USER=[[.AppName]]
DB_PASSWORD=secret
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFE=5m
DB_AUTO_MIGRATE=true
DB_SSL_MODE=disable      # use 'require' in production
[[- if .Redis ]]

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=20
REDIS_MIN_IDLE_CONNS=5
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_MAX_RETRIES=3
[[- end ]]
[[- if .Kafka ]]

# Kafka (leave empty to report "not_configured" in /health)
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=[[.AppName]]-group
[[- end ]]
[[- if .RabbitMQ ]]

# RabbitMQ (leave empty to report "not_configured" in /health)
RABBITMQ_DSN=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=[[.AppName]]-exchange
[[- end ]]

# Observability — pilih salah satu provider, comment sisanya
# ── OTel (kirim ke OTel Collector / Jaeger / Elastic APM via OTLP) ──────────
# OBSERVABILITY_PROVIDER=otel
# OTEL_TRACING_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318   # OTel Collector
# OTEL_EXPORTER_OTLP_HEADERS=                         # e.g. Authorization=Bearer <token>

# ── Elastic APM native (APM Go agent, lebih lengkap: profiling + error capture) ──
OBSERVABILITY_PROVIDER=[[.APM]]
OTEL_TRACING_ENABLED=[[if eq .APM "none"]]false[[else]]true[[end]]
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
ELASTIC_APM_SERVER_URL=http://localhost:8200
ELASTIC_APM_SERVICE_NAME=[[.AppName]]
ELASTIC_APM_ENVIRONMENT=development
ELASTIC_APM_SECRET_TOKEN=
# ELASTIC_APM_ACTIVE=false                             # set false untuk disable tanpa ganti provider

# ── Disable tracing ──────────────────────────────────────────────────────────
# OBSERVABILITY_PROVIDER=none

# Logger
LOG_LEVEL=info
LOG_TO_FILE=false
LOG_FILE_PATH=logs/app.log

# Structured log sinks → logs/{api,consumer,thirdparty,trace}.log
LOG_DIR=logs
LOG_ROTATION=size          # size = rotate by size | daily = one file per day (api-2006-01-02.log)
LOG_MAX_AGE_DAYS=30
LOG_BODY_MAX_BYTES=16384   # per request/response body cap in api.log & thirdparty.log
LOG_HTTP_BODIES=true       # set false to log headers+meta only (bodies become "[omitted]")

# External services
USER_SERVICE_URL=http://user-service:8080
ORDER_SERVICE_URL=http://order-service:8080

# Health check
HEALTH_PROBE_TIMEOUT=2s    # per-dependency timeout for DB/Redis/extra probes

# ── Notification add-ons (opsional — biarkan kosong jika tidak dipakai) ──────
# Aktifkan setelah menjalankan: wapgo add email  atau  wapgo add firebase

# SMTP (wapgo add email)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587              # 587=STARTTLS (recommended), 465=implicit TLS, 25=plain
# SMTP_USERNAME=noreply@example.com
# SMTP_PASSWORD=smtp_password
# SMTP_FROM=noreply@example.com
# SMTP_TIMEOUT=10s

# Firebase FCM (wapgo add firebase)
# Cara dapat key: Firebase Console → Project Settings → Service Accounts → Generate new private key
# FIREBASE_CREDENTIALS_JSON=
