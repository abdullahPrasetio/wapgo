package rabbitmq

import (
	"context"
	"fmt"
	"sync"
	"time"

	amqp "github.com/rabbitmq/amqp091-go"
	"github.com/rs/zerolog"
	"go.opentelemetry.io/otel"

	applogger "github.com/abdullahPrasetio/wapgo/pkg/logger"
)

// Message is the unit of data published or received via RabbitMQ.
type Message struct {
	RoutingKey string
	Body       []byte
	RequestID  string
}

// publishChan is the subset of amqp.Channel used by Publisher (enables mocking in tests).
type publishChan interface {
	ExchangeDeclare(name, kind string, durable, autoDelete, internal, noWait bool, args amqp.Table) error
	PublishWithContext(ctx context.Context, exchange, key string, mandatory, immediate bool, msg amqp.Publishing) error
	Close() error
}

// Publisher sends messages to a RabbitMQ topic exchange.
// It holds a persistent channel and retries once on publish failure by
// reopening the channel via the shared Connection.
type Publisher struct {
	conn     *Connection
	mu       sync.Mutex
	ch       publishChan // current channel; replaced on reconnect
	exchange string
	log      zerolog.Logger
}

// NewPublisher creates a Publisher that shares conn with other consumers and publishers.
// It opens an initial channel and declares the topic exchange.
func NewPublisher(conn *Connection, exchange string, log zerolog.Logger) (*Publisher, error) {
	p := &Publisher{conn: conn, exchange: exchange, log: log}
	if err := p.openChannel(); err != nil {
		return nil, err
	}
	return p, nil
}

// Publish sends msg to the exchange using the given routing key.
// If the channel is closed (e.g., after a broker restart), it reopens the
// channel once and retries before returning an error.
func (p *Publisher) Publish(ctx context.Context, msg Message) error {
	p.mu.Lock()
	defer p.mu.Unlock()

	err := p.publish(ctx, msg)
	if err == nil {
		return nil
	}

	// Channel may be stale — reopen once and retry.
	p.log.Warn().Err(err).Str("exchange", p.exchange).Msg("rabbitmq publish failed, reopening channel")
	if p.ch != nil {
		p.ch.Close() //nolint:errcheck
	}
	if rerr := p.openChannel(); rerr != nil {
		return fmt.Errorf("rabbitmq reconnect: %w; original: %v", rerr, err)
	}
	return p.publish(ctx, msg)
}

// Close shuts down the channel. The shared Connection is not closed here —
// call Connection.Close() during application shutdown.
func (p *Publisher) Close() error {
	p.mu.Lock()
	defer p.mu.Unlock()
	if p.ch != nil {
		return p.ch.Close()
	}
	return nil
}

// ── internal ────────────────────────────────────────────────────────────────

func (p *Publisher) openChannel() error {
	if p.conn == nil {
		return fmt.Errorf("rabbitmq: no connection")
	}
	ch, err := p.conn.Channel()
	if err != nil {
		return fmt.Errorf("rabbitmq publisher channel: %w", err)
	}
	if err := ch.ExchangeDeclare(p.exchange, "topic", true, false, false, false, nil); err != nil {
		ch.Close() //nolint:errcheck
		return fmt.Errorf("rabbitmq exchange declare: %w", err)
	}
	p.ch = ch
	return nil
}

func (p *Publisher) publish(ctx context.Context, msg Message) error {
	rid := msg.RequestID
	if rid == "" {
		rid = applogger.RequestIDFromContext(ctx)
	}
	headers := amqp.Table{"x-request-id": rid}
	otel.GetTextMapPropagator().Inject(ctx, amqpTableCarrier(headers))

	return p.ch.PublishWithContext(ctx, p.exchange, msg.RoutingKey, false, false,
		amqp.Publishing{
			ContentType:  "application/json",
			DeliveryMode: amqp.Persistent,
			Timestamp:    time.Now(),
			Body:         msg.Body,
			Headers:      headers,
		},
	)
}

// ── test helpers (package-private) ──────────────────────────────────────────

// newPublisherFrom creates a Publisher with a pre-built mock channel (used in tests only).
func newPublisherFrom(ch publishChan, _ interface{}, exchange string, log zerolog.Logger) *Publisher {
	return &Publisher{ch: ch, exchange: exchange, log: log}
}
