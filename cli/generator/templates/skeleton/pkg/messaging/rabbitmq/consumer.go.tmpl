package rabbitmq

import (
	"context"
	"fmt"
	"time"

	amqp "github.com/rabbitmq/amqp091-go"
	"github.com/rs/zerolog"
	"go.opentelemetry.io/otel"

	"github.com/abdullahPrasetio/wapgo/pkg/journal"
	applogger "github.com/abdullahPrasetio/wapgo/pkg/logger"
	"github.com/abdullahPrasetio/wapgo/pkg/observability"
)

// consumeChan is the subset of amqp.Channel used internally (enables mocking in tests).
type consumeChan interface {
	ExchangeDeclare(name, kind string, durable, autoDelete, internal, noWait bool, args amqp.Table) error
	QueueDeclare(name string, durable, autoDelete, exclusive, noWait bool, args amqp.Table) (amqp.Queue, error)
	QueueBind(name, key, exchange string, noWait bool, args amqp.Table) error
	Consume(queue, consumer string, autoAck, exclusive, noLocal, noWait bool, args amqp.Table) (<-chan amqp.Delivery, error)
	Close() error
}

// HandlerFunc processes a single RabbitMQ delivery.
// Return non-nil to Nack the message (it will be routed to the DLQ).
type HandlerFunc func(ctx context.Context, msg Message) error

// Consumer receives messages from a RabbitMQ topic exchange with DLQ support.
// It holds a reference to the shared Connection and opens its own channel per
// Subscribe call, reconnecting automatically if the channel is closed.
type Consumer struct {
	conn     *Connection
	exchange string
	dlx      string
	log      zerolog.Logger
}

// NewConsumer creates a Consumer that shares conn with other consumers and publishers.
// Pass the same *Connection to all Consumer and Publisher instances to ensure a
// single AMQP connection per process.
func NewConsumer(conn *Connection, exchange string, log zerolog.Logger) *Consumer {
	return &Consumer{
		conn:     conn,
		exchange: exchange,
		dlx:      exchange + ".dlx",
		log:      log,
	}
}

// Subscribe begins consuming messages from queueName matching routingKey.
// It blocks until ctx is cancelled, automatically reconnecting on channel
// or connection errors with exponential backoff (1 s → 30 s cap).
//
// Run Subscribe in a goroutine and cancel the ctx to stop it cleanly:
//
//	go consumer.Subscribe(ctx, "orders", "order.*", handler)
func (c *Consumer) Subscribe(ctx context.Context, queueName, routingKey string, handler HandlerFunc) error {
	bo := time.Second
	for {
		if ctx.Err() != nil {
			return nil
		}

		ch, err := c.conn.Channel()
		if err != nil {
			c.log.Error().Err(err).Str("queue", queueName).Dur("retry_in", bo).
				Msg("rabbitmq open channel failed")
			if !sleepBackoff(ctx, &bo) {
				return nil
			}
			continue
		}

		if err := c.declareExchanges(ch); err != nil {
			ch.Close() //nolint:errcheck
			c.log.Error().Err(err).Str("queue", queueName).Dur("retry_in", bo).
				Msg("rabbitmq declare failed")
			if !sleepBackoff(ctx, &bo) {
				return nil
			}
			continue
		}

		if err := c.declareQueues(ch, queueName, routingKey); err != nil {
			ch.Close() //nolint:errcheck
			c.log.Error().Err(err).Str("queue", queueName).Dur("retry_in", bo).
				Msg("rabbitmq queue setup failed")
			if !sleepBackoff(ctx, &bo) {
				return nil
			}
			continue
		}

		bo = time.Second // reset after successful setup

		// drain blocks until ctx is cancelled or the channel dies.
		if err := c.drain(ctx, ch, queueName, routingKey, handler); err != nil && ctx.Err() == nil {
			c.log.Error().Err(err).Str("queue", queueName).Dur("retry_in", bo).
				Msg("rabbitmq channel closed, reconnecting")
		}
		ch.Close() //nolint:errcheck

		if ctx.Err() != nil {
			return nil
		}
		if !sleepBackoff(ctx, &bo) {
			return nil
		}
	}
}

// Close is a no-op — the Consumer does not own the connection.
// Stop a Consumer by cancelling the context passed to Subscribe.
func (c *Consumer) Close() error { return nil }

// ── internal ────────────────────────────────────────────────────────────────

// declareExchanges declares the main topic exchange and its dead-letter exchange.
// Exposed as a method so tests can call it with a mock channel.
func (c *Consumer) declareExchanges(ch consumeChan) error {
	if err := ch.ExchangeDeclare(c.exchange, "topic", true, false, false, false, nil); err != nil {
		return fmt.Errorf("rabbitmq main exchange declare: %w", err)
	}
	if err := ch.ExchangeDeclare(c.dlx, "topic", true, false, false, false, nil); err != nil {
		return fmt.Errorf("rabbitmq dlx declare: %w", err)
	}
	return nil
}

// declareQueues declares the main queue (with DLX routing) and its DLQ, then
// binds both to their respective exchanges.
// Exposed as a method so tests can call it with a mock channel.
func (c *Consumer) declareQueues(ch consumeChan, queueName, routingKey string) error {
	dlqName := queueName + ".dlq"

	if _, err := ch.QueueDeclare(dlqName, true, false, false, false, nil); err != nil {
		return fmt.Errorf("rabbitmq dlq declare: %w", err)
	}
	if err := ch.QueueBind(dlqName, routingKey, c.dlx, false, nil); err != nil {
		return fmt.Errorf("rabbitmq dlq bind: %w", err)
	}

	qArgs := amqp.Table{
		"x-dead-letter-exchange":    c.dlx,
		"x-dead-letter-routing-key": routingKey,
	}
	if _, err := ch.QueueDeclare(queueName, true, false, false, false, qArgs); err != nil {
		return fmt.Errorf("rabbitmq queue declare: %w", err)
	}
	if err := ch.QueueBind(queueName, routingKey, c.exchange, false, nil); err != nil {
		return fmt.Errorf("rabbitmq queue bind: %w", err)
	}
	return nil
}

// drain consumes deliveries from ch until ctx is cancelled or the channel closes.
func (c *Consumer) drain(ctx context.Context, ch *amqp.Channel, queueName, routingKey string, handler HandlerFunc) error {
	deliveries, err := ch.Consume(queueName, "", false, false, false, false, nil)
	if err != nil {
		return fmt.Errorf("rabbitmq consume: %w", err)
	}

	chanClosed := ch.NotifyClose(make(chan *amqp.Error, 1))

	for {
		select {
		case <-ctx.Done():
			return nil
		case amqpErr, ok := <-chanClosed:
			if !ok || amqpErr == nil {
				return fmt.Errorf("channel closed")
			}
			return fmt.Errorf("channel closed: %s", amqpErr.Reason)
		case d, ok := <-deliveries:
			if !ok {
				return fmt.Errorf("deliveries channel closed")
			}
			c.handle(d, handler)
		}
	}
}

func (c *Consumer) handle(d amqp.Delivery, handler HandlerFunc) {
	rid := ""
	if v, ok := d.Headers["x-request-id"]; ok {
		rid = fmt.Sprint(v)
	}

	msgCtx := otel.GetTextMapPropagator().Extract(
		applogger.WithRequestID(context.Background(), rid), amqpTableCarrier(d.Headers))
	jctx, j := journal.Start(msgCtx, journal.KindConsumer)
	j.SetRequestID(rid)
	spanCtx, endSpan := observability.StartSpan(jctx, "rabbitmq.consume "+d.RoutingKey)

	start := time.Now()
	herr := handler(spanCtx, Message{
		RoutingKey: d.RoutingKey,
		Body:       d.Body,
		RequestID:  rid,
	})
	endSpan()

	j.SetTraceID(observability.TraceID(spanCtx))
	c.logConsumed(d, rid, j, time.Since(start), herr)

	if herr != nil {
		c.log.Error().Err(herr).Str("routing_key", d.RoutingKey).Msg("rabbitmq handler failed, routing to DLQ")
		d.Nack(false, false) //nolint:errcheck
		return
	}
	d.Ack(false) //nolint:errcheck
}

func (c *Consumer) logConsumed(d amqp.Delivery, rid string, j *journal.Journal, latency time.Duration, herr error) {
	status := "ok"
	if herr != nil {
		status = "error"
	}
	ev := applogger.Consumer().Info().
		Str("broker", "rabbitmq").
		Str("exchange", d.Exchange).
		Str("routing_key", d.RoutingKey).
		Str("request_id", rid).
		Str("trace_id", j.TraceID()).
		Dur("latency_ms", latency).
		Str("status", status).
		Interface("thirdparty", j.ThirdParties()).
		Interface("trace", j.Traces())
	if herr != nil {
		ev = ev.Str("error", herr.Error())
	}
	ev.Msg("consumed")
}

// sleepBackoff waits for bo duration (or ctx cancellation) and doubles bo up to 30 s.
// Returns false if ctx was cancelled during the wait.
func sleepBackoff(ctx context.Context, bo *time.Duration) bool {
	select {
	case <-ctx.Done():
		return false
	case <-time.After(*bo):
		if *bo < 30*time.Second {
			*bo *= 2
			if *bo > 30*time.Second {
				*bo = 30 * time.Second
			}
		}
		return true
	}
}

// amqpConnCloser is used by HealthCheck (enables mocking in tests).
type amqpConnCloser interface {
	Close() error
}

func healthCheckWithDialer(dsn string, dial func(string) (amqpConnCloser, error)) func(ctx context.Context) string {
	return func(_ context.Context) string {
		if dsn == "" {
			return "not_configured"
		}
		conn, err := dial(dsn)
		if err != nil {
			return fmt.Sprintf("down: %v", err)
		}
		conn.Close() //nolint:errcheck
		return "ok"
	}
}
